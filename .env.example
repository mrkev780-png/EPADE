# Fichier d'environnement
# Copier vers .env.local pour la configuration locale

# API
VITE_API_URL=https://api.ompdd.org
VITE_API_KEY=your_api_key_here

# Environnement
VITE_ENV=development

# Analytics
VITE_GA_ID=G-XXXXXXXX

# Langues supportées
VITE_SUPPORTED_LANGUAGES=fr,en,es
VITE_DEFAULT_LANGUAGE=fr
